# /var/www/mvbroker/.env
# IMPORTANTE: este arquivo aponta pro Supabase SELF-HOSTED da VPS.
# Nunca trocar por URLs do Lovable Cloud (*.supabase.co).

VITE_SUPABASE_URL=https://supabase.sistemamvbroker.com.br
VITE_SUPABASE_PUBLISHABLE_KEY=COLE_AQUI_O_ANON_KEY_DO_INFRA_ENV

SUPABASE_URL=https://supabase.sistemamvbroker.com.br
SUPABASE_PUBLISHABLE_KEY=COLE_AQUI_O_ANON_KEY_DO_INFRA_ENV
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_O_SERVICE_ROLE_KEY_DO_INFRA_ENV

# Google Maps (opcional — copie do .env atual se já usa)
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=
