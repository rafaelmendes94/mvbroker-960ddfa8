############################################
# DOMÍNIOS
############################################
DOMAIN_ROOT=sistemamvbroker.com.br
DOMAIN_APP=app.sistemamvbroker.com.br
DOMAIN_SUPABASE=supabase.sistemamvbroker.com.br
LETSENCRYPT_EMAIL=patrique.corretor@gmail.com

############################################
# SUPABASE SELF-HOSTED
# Gere segredos fortes:
#   openssl rand -base64 48
# JWT (ANON/SERVICE) tem que ser gerado com:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
############################################
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_senha
JWT_SECRET=CHANGE_ME_jwt_secret_minimo_32_chars_aleatorios
ANON_KEY=CHANGE_ME_jwt_anon_gerado_com_jwt_secret_acima
SERVICE_ROLE_KEY=CHANGE_ME_jwt_service_role_gerado_com_jwt_secret_acima

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_senha_studio

SITE_URL=https://app.sistemamvbroker.com.br
ADDITIONAL_REDIRECT_URLS=https://app.sistemamvbroker.com.br/**,https://sistemamvbroker.com.br/**
DISABLE_SIGNUP=false

# SMTP (opcional, deixe vazio se ainda não tem)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=MV Broker
SMTP_ADMIN_EMAIL=patrique.corretor@gmail.com

############################################
# SUPER ADMIN (usado por seed-admin.sh)
############################################
ADMIN_EMAIL=patrique.corretor@gmail.com
