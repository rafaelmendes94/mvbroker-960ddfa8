# =========================================================
#  MV Broker — variáveis de ambiente
# =========================================================
# NUNCA commite valores reais. Este arquivo só lista os nomes.
#
# Ambientes:
#   - Lovable Cloud  → injetadas pelo painel (integração Supabase)
#   - VPS self-host  → injetadas via --build-arg no Dockerfile
#                      (ver infra/update.sh)
# =========================================================

# Supabase (frontend / SSR)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Google Maps (frontend) — obrigatório na VPS para carregar o mapa
VITE_GOOGLE_MAPS_API_KEY=

# Supabase (server-side / admin) — só na VPS
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
